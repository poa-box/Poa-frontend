# Build-time public configuration (all NEXT_PUBLIC_* values are baked into the static export).

# Pimlico bundler key — required for passkey (ERC-4337) accounts and gasless transactions.
NEXT_PUBLIC_PIMLICO_API_KEY=

# ZK Email claim inbox (optional pair — BOTH must be set to enable the auto-fetch claim path).
# The address users send their verification email to (a Cloudflare Email Worker receives it)…
NEXT_PUBLIC_ZKEMAIL_INBOX=claim@poa.box
# …and the worker's HTTP endpoint the claim page polls for the raw signed message.
# Unset both to fall back to manual .eml upload only (the permissionless path, always available).
NEXT_PUBLIC_ZKEMAIL_INBOX_URL=
